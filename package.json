{
    "name": "biab",
    "version": "1.0.47",
    "description": "",
    "type": "module",
    "main": "build/index.js",
    "scripts": {
        "start": "tsx -e \"import('./src/api/server.ts').then(m => m.start())\"",
        "dev": "nodemon --exec \"tsx -r dotenv/config -e \\\"import('./src/api/server.ts').then(m => m.start())\\\"\"",
        "test": "mocha --package package.json",
        "nt": "nodemon --exec pnpm run test",
        "coverage": "nodemon --exec nyc mocha --package package.json",
        "bump": "pnpm version patch --no-git-tag-version && git add pnpm-lock.yaml",
        "deploy": "tsx -e \"import('./src/hosting/deploy.ts').then(m => m.deploy())\"",
        "reset": "tsx -r dotenv/config -e \"import('./src/scripts/reset.ts').then(m => m.reset())\""
    },
    "nodemonConfig": {
        "signal": "SIGKILL",
        "ext": "ts, js, jsx, tsx, json"
    },
    "nyc": {
        "reporter": [
            "html"
        ]
    },
    "mocha": {
        "loader": "tsx/esm",
        "require": [
            "dotenv/config"
        ],
        "spec": [
            "src/**/*.test.ts"
        ],
        "timeout": 0
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "ajv": "^8.11.0",
        "apple-auth": "^1.0.7",
        "apple-signin-auth": "^1.7.4",
        "axios": "^0.27.2",
        "bcrypt": "^5.0.1",
        "cuid": "^2.1.8",
        "date-fns": "^4.1.0",
        "JSONStream": "^1.3.5",
        "jsonwebtoken": "^8.5.1",
        "next-auth": "^4.10.3",
        "orma": "^1.0.280",
        "p-limit": "^7.3.0",
        "pg": "^8.8.0",
        "retry": "^0.13.1",
        "stopcock": "^1.1.0",
        "tsx": "^4.21.0",
        "yay_json": "^1.0.33"
    },
    "devDependencies": {
        "@jsdevtools/npm-publish": "^1.4.3",
        "@types/node": "^18.7.16",
        "chai": "^4.3.6",
        "db-migrate": "^0.11.13",
        "db-migrate-pg": "^1.2.2",
        "dotenv": "^16.0.2",
        "git-rev-sync": "^3.0.2",
        "mocha": "^10.0.0",
        "nyc": "^15.1.0",
        "sinon": "^14.0.0"
    }
}
